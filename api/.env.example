# Copy to .env and adjust for deployment. All values are optional in dev.

# Comma-separated allowed CORS origins. Defaults to the local dev origins
# (http://localhost:5173,http://localhost:4173) — never "*". In production set
# this to the deployed frontend origin, e.g.:
# LASTECHO_CORS_ORIGINS=https://lastecho.vercel.app

# --- admin auth -----------------------------------------------------------
# The admin (outreach-queue) and triage endpoints require a bearer token. Set a
# password to enable admin: the frontend POSTs to /api/admin/login to exchange
# username+password for the token, then sends it as the X-Admin-Token header.
# With no password set, admin/triage endpoints fail closed (503).
# LASTECHO_ADMIN_USER=admin
# LASTECHO_ADMIN_PASSWORD=change-me
# Optional: a stable token so admin sessions survive restarts (otherwise a fresh
# random token is generated each process start).
# LASTECHO_ADMIN_TOKEN=

# Per-IP request cap (sliding 60s window). 0 disables. Default 120.
# LASTECHO_RATE_LIMIT_PER_MIN=120

# Run the triage sweep once at startup (backgrounded). Off by default — it does
# live ROR lookups + paid Anthropic calls. Use POST /api/triage/run on demand.
# LASTECHO_RUN_SWEEP_ON_STARTUP=false

# Absolute path to the dataset, if you keep it outside api/data/.
# LASTECHO_DATA_PATH=/abs/path/to/languages.json

# Outreach drafting via Claude. Unset -> outreach.py falls back to a
# templated draft, so the triage sweep still runs end-to-end offline.
# ANTHROPIC_API_KEY=sk-ant-...

# How many of the most urgent languages the triage sweep drafts per run.
# LASTECHO_TRIAGE_TOP_N=15

# Days a sent draft waits before the admin can mark it "no reply" and
# escalate to the next tier (local -> continental -> global).
# LASTECHO_ESCALATE_AFTER_DAYS=7

# TTL (days) for the national-tier ROR lookup cache.
# LASTECHO_ROR_CACHE_TTL_DAYS=30

# Real emailable organizations matched into the local rung of the ladder.
# Defaults to the file the frontend ships (client/src/data/language_organizations.json).
# LASTECHO_ORGANIZATIONS_PATH=/abs/path/to/language_organizations.json

# --- SMTP: real email sending ---------------------------------------------
# The POST /api/outreach-queue/{id}/send endpoint actually delivers an approved
# draft to the matched organization's address. Without HOST + FROM it returns
# 503 (it never silently pretends to send); mark-sent still works regardless.
# send() retries transient connection failures 3x with backoff (see mailer.py).
#
# Production: use a transactional email provider's SMTP relay (not a personal
# Gmail account — it will get rate-limited/flagged at any real volume).
# Postmark example (https://postmarkapp.com -> Servers -> SMTP):
# LASTECHO_SMTP_HOST=smtp.postmarkapp.com
# LASTECHO_SMTP_PORT=587
# LASTECHO_SMTP_USER=<postmark-server-token>
# LASTECHO_SMTP_PASSWORD=<postmark-server-token>   # same token, used as both
# LASTECHO_SMTP_FROM=outreach@yourdomain.org        # must be a verified Sender Signature
# LASTECHO_SMTP_USE_TLS=true
#
# Before going live: verify your sending domain in the provider's dashboard
# and add the SPF/DKIM DNS records it gives you, or mail to real institutions
# will land in spam or get rejected outright.
