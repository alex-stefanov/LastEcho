# Copy to .env and adjust for deployment. All values are optional in dev.

# Comma-separated allowed CORS origins. Default "*" (fine for the hackathon).
# In production set this to the frontend origin, e.g.:
# LASTECHO_CORS_ORIGINS=https://lastecho.vercel.app
LASTECHO_CORS_ORIGINS=*

# Absolute path to the dataset, if you keep it outside api/data/.
# LASTECHO_DATA_PATH=/abs/path/to/languages.json

# Outreach drafting via Claude. Unset -> outreach.py falls back to a
# templated draft, so the triage sweep still runs end-to-end offline.
# ANTHROPIC_API_KEY=sk-ant-...

# How many of the most urgent languages the triage sweep drafts per run.
# LASTECHO_TRIAGE_TOP_N=15

# Days a sent draft waits before the admin can mark it "no reply" and
# escalate to the next tier (local -> continental -> global).
# LASTECHO_ESCALATE_AFTER_DAYS=7

# TTL (days) for the national-tier ROR lookup cache.
# LASTECHO_ROR_CACHE_TTL_DAYS=30
