# Copy this file to .env.local and adjust. .env.local is gitignored.

# Base URL of the deployed API. Leave empty in dev — Vite proxies /api to the
# local FastAPI server (see vite.config.ts).
# VITE_API_BASE=https://api.lastecho.example.org

# NOTE: admin credentials are NOT configured here. Admin auth is enforced
# server-side; you log in through /admin, which exchanges your username and
# password (set via LASTECHO_ADMIN_* on the API) for a token. No secret is ever
# embedded in the client bundle.
